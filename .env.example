# Primary RPC (used for reads + sign). Alchemy recommended.
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# WebSocket URL for instant block/mempool events (optional, derived from RPC_URL if https)
# WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Multi-RPC broadcast endpoints (comma-separated). Defaults to a public list.
# BROADCAST_URLS=https://rpc.flashbots.net,https://rpc.titanbuilder.xyz,https://rpc.beaverbuild.org,https://1rpc.io/eth

# Telegram notifications (optional)
TG_BOT_TOKEN=
TG_CHAT_ID=

# Gas strategy
GAS_MULTIPLIER=5
MIN_TIP_GWEI=1
MAX_TIP_GWEI=50
MEMPOOL_OUTBID_PCT=15
# GAS_TIP_GWEI=3  # override with fixed priority fee
